{
  "installCommand": "cd flint-web/frontend && npm install",
  "buildCommand": "cd flint-web/frontend && npx vite build && node ../scripts/postbuild.js",
  "outputDirectory": "flint-web/frontend/dist",
  "routes": [
    { "src": "/", "dest": "/home.html" },
    { "src": "/((?!.*\\.[^/]+$).*)", "dest": "/index.html" }
  ]
}
